# ─── Backend (Railway: backend service) ───────────────────────────────────────

# Database — Railway автоматично надає DATABASE_URL через PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT — згенеруй довгий випадковий рядок
JWT_SECRET=change_this_to_a_long_random_string_in_production

# App port (Railway підставляє $PORT автоматично)
PORT=4000

# Telegram (необов'язково — сповіщення)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ─── Локальна розробка (docker-compose) ──────────────────────────────────────

DB_USER=crm
DB_PASSWORD=crm123
DB_NAME=currency_crm

# ─── Frontend (Railway: frontend service) ─────────────────────────────────────

# URL бекенду — вставте після деплою бекенду на Railway
# Формат: https://your-backend.up.railway.app/api
VITE_API_URL=
